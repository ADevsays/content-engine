# Mandatory settings
N8N_DOMAIN=n8n.yourdomain.com
N8N_ENCRYPTION_KEY=generate-a-secure-random-key-here
GENERIC_TIMEZONE=Europe/Madrid
HOST_PORT=5678


# 1. ElevenLabs (Voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# 2. Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 3. Supabase Integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_service_role_or_anon_key

# 4. Postgres Database Connection
POSTGRES_HOST=your_postgres_host_here
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# 5. Cohere API (AI Embeddings)
COHERE_API_KEY=your_cohere_api_key_here

# 6. Google Gemini API (AI Text/Transcription)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# 7. Notion API
NOTION_API_KEY=secret_your_notion_integration_token_here

# 8. Google Drive (Google OAuth2 API)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here


