# ============================================
# MANDATORY
# ============================================

# Domain where n8n will be accessible (Dokploy/Traefik routes to this)
N8N_DOMAIN=n8n.yourdomain.com

# Encryption key for credentials stored in n8n (generate with: openssl rand -hex 16)
N8N_ENCRYPTION_KEY=generate-a-secure-random-key-here

# Timezone (default: America/Bogota)
GENERIC_TIMEZONE=America/Bogota

# ============================================
# OPTIONAL — API keys for imported credentials
# Leave empty if you don't use the service yet.
# ============================================

# ElevenLabs (Voice generation)
ELEVENLABS_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=

# Postgres Database
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Cohere API (AI Embeddings)
COHERE_API_KEY=

# Google Gemini API
GOOGLE_GEMINI_API_KEY=

# Notion API
NOTION_API_KEY=

# Google Drive (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
