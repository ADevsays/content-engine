# ============================================
# N8N CONFIGURATION (Required)
# ============================================

# Domain where n8n will be accessible (Dokploy/Traefik routes to this)
N8N_DOMAIN=n8n.yourdomain.com

# Encryption key for credentials stored in n8n (generate with: openssl rand -hex 16)
N8N_ENCRYPTION_KEY=

# Timezone (used for cron triggers and timestamps)
GENERIC_TIMEZONE=America/Bogota

# ============================================
# SUPABASE + POSTGRES (Required)
# Used by: content, generate_script, generate_voice, confirm_script, confirm_audio
# ============================================

# Supabase project URL and anon/service key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=

# Direct Postgres connection (used for SQL queries in workflows)
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ============================================
# TELEGRAM BOT (Required)
# Used by: content, generate_script, generate_voice, confirm_script, confirm_audio
# ============================================

TELEGRAM_BOT_TOKEN=

# ============================================
# ELEVENLABS (Required for voice generation)
# Used by: generate_voice (direct API + codecollab proxy)
# ============================================

ELEVENLABS_API_KEY=



# ============================================
# NOTION (Required for content publishing)
# Used by: confirm_audio (creates database pages with audio links)
# ============================================

NOTION_API_KEY=
NOTION_DATABASE_ID=

# ============================================
# GOOGLE DRIVE OAuth2 (Required for file management)
# Used by: confirm_audio (deletes temp audio files after publishing)
# ============================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
